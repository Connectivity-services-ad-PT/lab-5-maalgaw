{
  "info": {
    "_postman_id": "fit4110-lab05-iot",
    "name": "FIT4110 Lab 05 - IoT Ingestion",
    "description": "IoT Ingestion API tests for Docker Compose stack",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Health Check - Status 200', function() {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Health Check - Has status ok', function() {",
              "  const jsonData = pm.response.json();",
              "  pm.expect(jsonData.status).to.equal('ok');",
              "});",
              "pm.test('Health Check - Has service name', function() {",
              "  const jsonData = pm.response.json();",
              "  pm.expect(jsonData.service).to.equal('iot-ingestion');",
              "});",
              "pm.test('Health Check - Has version', function() {",
              "  const jsonData = pm.response.json();",
              "  pm.expect(jsonData).to.have.property('version');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health"
          ]
        }
      }
    },
    {
      "name": "Get Latest Readings",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Get Latest Readings - Status 200', function() {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Get Latest Readings - Has items property', function() {",
              "  const jsonData = pm.response.json();",
              "  pm.expect(jsonData).to.have.property('items');",
              "});",
              "pm.test('Get Latest Readings - Items is array', function() {",
              "  const jsonData = pm.response.json();",
              "  pm.expect(jsonData.items).to.be.an('array');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer local-dev-token",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/readings/latest",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "readings",
            "latest"
          ]
        }
      }
    }
  ]
}
